{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/jianhongtu/rcabench/rcabench-purple-agent:latest",
    entrypoint: [
      "uv",
      "run",
      "purple_agent_server.py",
      "--host",
      "0.0.0.0", 
      "--port", 
      "8080",
      "--card-url",
      "http://purple-agent:8080"
    ],
    env: {
      PROXY_URL: "${slots.proxy.url}",
      LOG_LEVEL: "INFO",
      OPENAI_API_KEY: "${config.openai_api_key}",
      MODEL: "${config.model}",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8080 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
      model: { type: "string" }
    },
    required: [],
    additionalProperties: false,
  },
  slots: {
    proxy: { kind: "a2a" },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: {
    a2a: "a2a",
  },
}
